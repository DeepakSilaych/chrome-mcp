{
  "private": true,
  "name": "livemcp",
  "description": "MCP server that gives AI direct access to your real browser tabs",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Deepak Silaych",
  "repository": {
    "type": "git",
    "url": "https://github.com/DeepakSilaych/chrome-mcp"
  },
  "workspaces": ["shared", "server", "extension"],
  "scripts": {
    "build": "npm run build:server && npm run build:extension",
    "build:server": "npm run compile -w livemcp",
    "build:extension": "npm run compile -w @livemcp/extension",
    "hub": "node server/dist/hub.js",
    "verify-ws": "node server/scripts/verify-ws.mjs"
  },
  "engines": {
    "node": ">=18"
  }
}
