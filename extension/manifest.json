{
  "manifest_version": 3,
  "name": "Chrome MCP Bridge",
  "version": "1.1.0",
  "description": "Bridge for chrome-mcp server",
  "permissions": ["tabs", "activeTab", "scripting", "cookies", "debugger", "storage"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Chrome MCP",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  }
}
